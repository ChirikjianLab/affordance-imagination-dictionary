<?xml version="1.0"?>
<robot name="sphere_agent">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/> <!-- Assuming a small mass for the droplet -->
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/> <!-- Approximated for a sphere -->
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/> <!-- Diameter is 0.01m, so radius is half -->
      </geometry>
      <material name="water">
        <color rgba="0.0 0.5 1.0 0.5"/> <!-- Semi-transparent blue to represent water -->
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
    </collision>
  </link>
</robot>
