<?xml version="1.0"?>
<robot name="cube_affordance_tester">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/> <!-- Assuming a mass of 0.1 kg -->
      <inertia ixx="0.00010417" ixy="0" ixz="0" iyy="0.00010417" iyz="0" izz="0.00010417"/> <!-- Assuming uniform density -->
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/> <!-- Cube dimensions -->
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/> <!-- Yellow color for visibility -->
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/> <!-- Cube dimensions -->
      </geometry>
    </collision>
  </link>
</robot>
